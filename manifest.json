{
  "manifest_version": 3,
  "name": "Video Popup Player",
  "version": "1.0.0",
  "description": "Open direct video links in an extension player page instead of downloading.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Video Popup Player",
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/player/player.html",
        "src/player/player.css",
        "src/player/player.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
